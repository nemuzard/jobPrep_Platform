<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jobprep.jobprep_platform.mapper.QuestionListMapper">

    <sql id="questionListColumns">
        question_list_id,
        name,
        type,
        description,
        created_at,
        updated_at
    </sql>

    <insert id="insert" parameterType="com.jobprep.jobprep_platform.model.entity.QuestionList" useGeneratedKeys="true" keyProperty="questionListId">
        INSERT INTO question_list (
            name,
            type,
            description
        ) VALUES (
            #{name},
            #{type},
            #{description}
        )
    </insert>

    <select id="findById" resultType="com.jobprep.jobprep_platform.model.entity.QuestionList">
        SELECT
            <include refid="questionListColumns"/>
        FROM question_list
        WHERE question_list_id = #{questionListId}
    </select>

    <select id="findAll" resultType="com.jobprep.jobprep_platform.model.entity.QuestionList">
        SELECT
            <include refid="questionListColumns"/>
        FROM question_list
        ORDER BY created_at DESC, question_list_id DESC
    </select>

    <update id="update" parameterType="com.jobprep.jobprep_platform.model.entity.QuestionList">
        UPDATE question_list
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="type != null">type = #{type},</if>
            <if test="description != null">description = #{description},</if>
            updated_at = NOW()
        </set>
        WHERE question_list_id = #{questionListId}
    </update>

    <delete id="deleteById">
        DELETE FROM question_list
        WHERE question_list_id = #{questionListId}
    </delete>

</mapper>
