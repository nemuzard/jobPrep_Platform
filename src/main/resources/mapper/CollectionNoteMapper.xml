<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jobprep.jobprep_platform.mapper.CollectionNoteMapper">

    <select id="findUserCollectedNoteIds" resultType="integer">
        SELECT DISTINCT cn.note_id
        FROM collection_note cn
        INNER JOIN collection c ON c.collection_id = cn.collection_id
        WHERE c.creator_id = #{userId}
        <choose>
            <when test="noteIds != null and noteIds.size > 0">
                AND cn.note_id IN
                <foreach collection="noteIds" item="noteId" open="(" separator="," close=")">
                    #{noteId}
                </foreach>
            </when>
            <otherwise>
                AND 1 = 0
            </otherwise>
        </choose>
    </select>

    <select id="filterCollectionIdsByNoteId" resultType="integer">
        SELECT collection_id
        FROM collection_note
        WHERE note_id = #{noteId}
        <choose>
            <when test="collectionIds != null and collectionIds.size > 0">
                AND collection_id IN
                <foreach collection="collectionIds" item="collectionId" open="(" separator="," close=")">
                    #{collectionId}
                </foreach>
            </when>
            <otherwise>
                AND 1 = 0
            </otherwise>
        </choose>
    </select>

    <insert id="insert" parameterType="com.jobprep.jobprep_platform.model.entity.CollectionNote">
        INSERT IGNORE INTO collection_note (
            collection_id,
            note_id
        ) VALUES (
            #{collectionId},
            #{noteId}
        )
    </insert>

    <delete id="deleteByCollectionId">
        DELETE FROM collection_note
        WHERE collection_id = #{collectionId}
    </delete>

    <delete id="deleteByCollectionIdAndNoteId">
        DELETE FROM collection_note
        WHERE collection_id = #{collectionId}
          AND note_id = #{noteId}
    </delete>

</mapper>
